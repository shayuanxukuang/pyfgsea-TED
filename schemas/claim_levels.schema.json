{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pyfgsea.local/ted-mad/claim_levels.schema.json",
  "title": "TED-MAD claim levels",
  "type": "object",
  "required": ["claim_levels"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "claim_levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["level", "label", "claim", "missing"],
        "additionalProperties": true,
        "properties": {
          "level": {
            "type": "number",
            "minimum": 0
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "claim": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "missing": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
